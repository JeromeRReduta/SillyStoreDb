{
    "name": "silly_store_backend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "nodemon -w src/server -x tsx --env-file=.env.development src/server/main.ts",
        "dev:strict": "npx eslint . && npm run dev",
        "start": "tsx --env-file=.env.production src/server/main.ts",
        "test": "tsx --env-file=.env.development src/server/test.ts",
        "db:schema": "psql -d silly_store_db -f src/infrastructure/psql/schema.sql -U practice",
        "db:seed": "tsx --env-file=.env.development src/infrastructure/psql/seed.ts",
        "db:reset": "npm run db:schema && npm run db:seed",
        "fresh-test": "npm run db:reset && npm run test",
        "lint": "npx eslint .",
        "see-big-number": "git ls-files | grep '\\.ts' | grep -v 'test' | xargs wc -l | sort -rn"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^22.19.17",
        "@types/pg": "^8.20.0",
        "eslint": "^10.1.0",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "nodemon": "^3.1.10",
        "ts-prune": "^0.10.3",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "depcheck": "^1.4.7",
        "dotenv": "^17.3.1",
        "eslint-plugin-import-x": "^4.16.2",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "pg": "^8.20.0",
        "silly-store-common": "file:/SillyStoreCommon",
        "tslog": "^4.10.2",
        "tsx": "^4.19.3"
    }
}
