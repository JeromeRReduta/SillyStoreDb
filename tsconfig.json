{
    "compilerOptions": {
        "typeRoots": ["./types"],
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "nodenext",
        "lib": ["ESNext", "DOM"],
        "moduleResolution": "nodenext",
        "strict": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "outDir": "./dist"
    },
    "include": [
        "src/**/*.ts",
        "vite-env.d.ts",
        "SillyStoreCommon/**/*.ts",
        "eslint.config.ts",
        "src/configs/.ts",
        "src/application/services/ClientProductService.ts.OLD"
    ],
    "files": ["src/server/main.ts"]
}
